{
  "manifest_version": 3,
  "name": "MaestraIA Sync",
  "version": "1.0.3",
  "description": "Sincroniza calificaciones de Richmond a MaestraIA automáticamente.",
  "permissions": ["storage", "notifications", "tabs"],
  "host_permissions": ["https://richmondlp.com/*", "https://*.maestraia.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://richmondlp.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://richmondlp.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MaestraIA Sync",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
