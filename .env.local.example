# .env.local.example — copy to .env.local and fill in values

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

ANTHROPIC_API_KEY=your-anthropic-api-key-here

ENCRYPTION_KEY=generate-with: openssl rand -hex 32

SENTRY_DSN=your-sentry-dsn-here

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DIARY_URL=http://localhost:3000

# Set to 'true' to preview diary microsite on localhost without a subdomain
NEXT_PUBLIC_FORCE_DIARY_SITE=false
