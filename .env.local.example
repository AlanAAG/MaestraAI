# .env.local.example — copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────────────────
# Supabase — https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Encryption key for Richmond credentials — generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DIARY_URL=http://localhost:3000

# Set to 'true' to preview diary microsite on localhost without a subdomain
NEXT_PUBLIC_FORCE_DIARY_SITE=false

# ─────────────────────────────────────────────────────────────────────────────
# Security — REQUIRED in production
# ─────────────────────────────────────────────────────────────────────────────

# Cron job authentication secret — generate with:
#   openssl rand -hex 32
# Add the same value to Vercel → Settings → Environment Variables AND to
# vercel.json cron job headers (or Vercel Cron will pass it automatically).
CRON_SECRET=generate-with-openssl-rand-hex-32

# CSRF token HMAC secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Only used if you wire up per-form CSRF tokens (middleware Origin-check covers
# all API mutations by default; this is an extra layer for sensitive forms).
CSRF_SECRET=generate-with-node-crypto-randomBytes-32

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting — Upstash Redis (required in production)
# Create a free Serverless Redis database at https://console.upstash.com
# then copy the REST URL and token from the database dashboard.
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR-REGION-DATABASE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# ─────────────────────────────────────────────────────────────────────────────
# Error Monitoring — Sentry (optional but recommended)
# Create a Next.js project at https://sentry.io → get DSN from
# Settings → Projects → your-project → Client Keys (DSN)
# Auth token: https://sentry.io → Settings → Auth Tokens → Create New Token
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# ─────────────────────────────────────────────────────────────────────────────
# Image enrichment — Unsplash (optional)
# https://unsplash.com/developers → New Application
# Free tier: 50 requests/hour. Without this key, materials use text descriptions.
# ─────────────────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here
